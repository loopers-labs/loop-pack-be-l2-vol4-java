{
  "uid": "pg-resilience",
  "title": "PG Resilience (Round 6)",
  "tags": ["round6", "resilience4j", "pg"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Circuit State (pgCircuit) - line at 1 = that state is ACTIVE",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "custom": { "drawStyle": "line", "stepAfter": true, "fillOpacity": 20 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "resilience4j_circuitbreaker_state{name=\"pgCircuit\"}", "legendFormat": "{{state}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failure rate / Slow-call rate (%)  [>=50% opens circuit]",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "resilience4j_circuitbreaker_failure_rate{name=\"pgCircuit\"}", "legendFormat": "failure_rate" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "resilience4j_circuitbreaker_slow_call_rate{name=\"pgCircuit\"}", "legendFormat": "slow_call_rate" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Payment API latency p95 / p99 (sec) - POST /api/v1/payments",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/v1/payments\"}[1m])) by (le))", "legendFormat": "p95" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/v1/payments\"}[1m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Circuit calls by kind: successful / failed (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (kind) (rate(resilience4j_circuitbreaker_calls_seconds_count{name=\"pgCircuit\"}[1m]))", "legendFormat": "{{kind}}" }
      ]
    }
  ]
}
